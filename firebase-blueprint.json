{
  "entities": {
    "Destination": {
      "title": "Destination",
      "description": "A tourist destination in Bukidnon",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "rating": { "type": "number" },
        "entranceFee": { "type": "number" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "address": { "type": "string" }
          }
        },
        "category": { "type": "string" }
      },
      "required": ["name", "description", "images", "location", "category"]
    },
    "FoodSpot": {
      "title": "Food Spot",
      "description": "A place to eat in Bukidnon",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "priceRange": { "type": "string" },
        "image": { "type": "string" },
        "description": { "type": "string" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "address": { "type": "string" }
          }
        },
        "rating": { "type": "number" },
        "menu": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "price": { "type": "string" },
              "category": { "type": "string" }
            }
          }
        }
      },
      "required": ["name", "image", "description", "location"]
    },
    "Event": {
      "title": "Event",
      "description": "A local event or festival",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "date": { "type": "string" },
        "month": { "type": "string" },
        "description": { "type": "string" },
        "location": { "type": "string" },
        "image": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["name", "date", "description", "location", "image", "category"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A booking request for a local buddy, food spot, destination, or event",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "buddyId": { "type": "string" },
        "buddyName": { "type": "string" },
        "destinationId": { "type": "string" },
        "destinationName": { "type": "string" },
        "foodSpotId": { "type": "string" },
        "foodSpotName": { "type": "string" },
        "eventId": { "type": "string" },
        "eventName": { "type": "string" },
        "type": { "type": "string", "enum": ["buddy", "food", "destination", "event"] },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "date", "status", "createdAt", "type"]
    },
    "Test": {
      "title": "Test",
      "description": "Used to test database connection",
      "type": "object",
      "properties": {
        "connection": { "type": "string" }
      }
    },
    "Admin": {
      "title": "Admin",
      "description": "An administrative user",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "destinations": { "schema": "Destination", "description": "Tourist spots" },
    "foodSpots": { "schema": "FoodSpot", "description": "Eateries" },
    "events": { "schema": "Event", "description": "Local festivals and events" },
    "bookings": { "schema": "Booking", "description": "User bookings" },
    "test": { "schema": "Test", "description": "Connection test" },
    "admins": { "schema": "Admin", "description": "Admin users" }
  }
}
