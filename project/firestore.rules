rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny for all collections
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidBooking(data) {
      return data.keys().hasAll(['userId', 'userName', 'userEmail', 'date', 'status', 'createdAt', 'type']) &&
             data.userId == request.auth.uid &&
             data.userName is string && data.userName.size() <= 200 &&
             data.userEmail is string && data.userEmail.size() <= 200 &&
             data.date is string &&
             data.status in ['pending', 'confirmed', 'cancelled'] &&
             data.createdAt == request.time &&
             data.type in ['buddy', 'food', 'destination', 'event'];
    }

    function isValidDestination(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.description is string && data.description.size() <= 5000 &&
             data.category is string &&
             data.location is map &&
             data.location.address is string;
    }

    function isValidFoodSpot(data) {
      return data.name is string && data.name.size() > 0 &&
             data.description is string &&
             data.location is map;
    }

    function isValidEvent(data) {
      return data.name is string &&
             data.date is string &&
             data.location is string;
    }

    // --- Collections ---

    // Connection test document
    match /test/connection {
      allow read: if true;
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      // Allow bootstrapping if email matches the user
      allow write: if (adminId == request.auth.uid && request.auth.token.email == 's.cervantes.aaronclyde@cmu.edu.ph') || isAdmin();
    }

    match /destinations/{destId} {
      allow read: if true;
      allow create: if isAdmin() && isValidDestination(incoming());
      allow update: if isAdmin() && isValidDestination(incoming());
      allow delete: if isAdmin();
    }

    match /foodSpots/{foodId} {
      allow read: if true;
      allow create: if isAdmin() && isValidFoodSpot(incoming());
      allow update: if isAdmin() && isValidFoodSpot(incoming());
      allow delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isAdmin() && isValidEvent(incoming());
      allow update: if isAdmin() && isValidEvent(incoming());
      allow delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      // Users can only read their own bookings, admins see all
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      allow create: if isSignedIn() && isValidBooking(incoming());
      
      allow update: if isAdmin() || 
                      (isOwner(existing().userId) && 
                       incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
                       incoming().status == 'cancelled');
                       
      allow delete: if isAdmin();
    }
  }
}
